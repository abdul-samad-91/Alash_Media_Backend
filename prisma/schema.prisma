// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
//   previewFeatures = ["fullTextIndex"]
}

datasource db {
  provider = "mysql"
  url      =  env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  password String
  role     String  @default("editor") // admin, editor
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  blogs   Blog[]
}

model Author {
  id       Int     @id @default(autoincrement())
  name     String
  slug     String  @unique
  photo    String?
  shortBio String
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  blogs Blog[]

  @@map("authors")
}

model Category {
  id               Int     @id @default(autoincrement())
  name             String  @unique
  slug             String  @unique
  description      String?
  parentCategoryId Int?
  isActive         Boolean @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  parentCategory Category?  @relation("CategoryToParent", fields: [parentCategoryId], references: [id], onDelete: SetNull)
  subCategories  Category[]  @relation("CategoryToParent")
  blogs          Blog[]

  @@map("categories")
}

model Blog {
  id               Int     @id @default(autoincrement())
  title            String
  slug             String  @unique
  subtitle         String?
  shortDescription String
  content          String  @db.LongText
  mainContentOne   String?
  mainContentTwo   String?
  featuredImage    String
  imageCaption     String?
  status           String  @default("draft") // draft, published
  publishedDate    DateTime?
  views            Int     @default(0)
  readTime         String?
  isActive         Boolean @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Foreign Keys
  authorId Int
  categoryId Int
  createdById Int?

  // Relations
  author        Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category      Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdBy     User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  
  tags          BlogTag[]
  contentBlocks BlogContentBlock[]
  sections      BlogSection[]

  @@index([slug])
  @@index([authorId])
  @@index([categoryId])
  @@fulltext([title, content])
  @@map("blogs")
}

model BlogTag {
  id    Int    @id @default(autoincrement())
  tag   String
  blogId Int

  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@map("blog_tags")
}

model BlogContentBlock {
  id      Int    @id @default(autoincrement())
  blockId Int
  heading String?
  text    String?
  blogId  Int

  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@map("blog_content_blocks")
}

model BlogSection {
  id      Int    @id @default(autoincrement())
  sectionId Int
  heading String?
  text    String?
  blogId  Int

  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@map("blog_sections")
}

model Banner {
  id        Int     @id @default(autoincrement())
  title     String
  description String?
  image     String
  link      String?
  position  Int     @default(0)
  isActive  Boolean @default(true)
  startDate DateTime @default(now())
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}

model Gallery {
  id        Int    @id @default(autoincrement())
  title     String
  description String?
  type      String // photo, video
  category  String @default("general")
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  items GalleryItem[]

  @@map("galleries")
}

model GalleryItem {
  id          Int    @id @default(autoincrement())
  title       String?
  url         String
  thumbnail   String?
  description String?
  displayOrder Int   @default(0)
  galleryId   Int

  gallery Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@map("gallery_items")
}

model Vote {
  id          Int    @id @default(autoincrement())
  title       String
  description String?
  image       String?
  isActive    Boolean @default(true)
  startDate   DateTime @default(now())
  endDate     DateTime?
  isExpired   Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  options VoteOption[]

  @@map("votes")
}

model VoteOption {
  id     Int    @id @default(autoincrement())
  text   String
  votes  Int    @default(0)
  voteId Int

  vote Vote @relation(fields: [voteId], references: [id], onDelete: Cascade)

  @@map("vote_options")
}
